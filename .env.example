# Tapas QA 테스트 계정 (이메일 로그인)
# 실제 비밀번호는 .env 파일에만 넣고, .env는 절대 git에 commit하지 마세요!

TAPAS_EMAIL=your-test-account@example.com
TAPAS_PASSWORD=your-password-here

# 소셜 로그인 테스트 계정
FACEBOOK_EMAIL=your-facebook-test@example.com
FACEBOOK_PASSWORD=your-facebook-password
GOOGLE_EMAIL=your-google-test@example.com
GOOGLE_PASSWORD=your-google-password

# 테스트 대상 환경
TAPAS_BASE_URL=https://tapas.io

# Mature 미인증 전용 계정 (연령 인증 미완료 상태 — TPS-064 용)
TAPAS_UNVERIFIED_EMAIL=your-unverified-account@example.com
TAPAS_UNVERIFIED_PASSWORD=your-password-here

# Slack 알림
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url