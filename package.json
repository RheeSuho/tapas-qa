{
  "name": "tapas-qa",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "bddgen": "bddgen",
    "test": "bddgen && playwright test",
    "test:bdd": "bddgen && playwright test --project=chromium",
    "test:bdd:headed": "bddgen && playwright test --project=chromium --headed",
    "test:smoke": "bddgen && playwright test --project=chromium --grep @smoke",
    "test:smoke:headed": "bddgen && playwright test --project=chromium --grep @smoke --headed",
    "test:smoke:slack": "bddgen && playwright test --project=chromium --grep @smoke; node scripts/notify-slack.js Smoke https://rheesuho.github.io/tapas-qa",
    "test:bdd:slack": "bddgen && playwright test --project=chromium; node scripts/notify-slack.js Regression https://rheesuho.github.io/tapas-qa",
    "test:qa": "TAPAS_BASE_URL=https://qa.tapas.io bddgen && TAPAS_BASE_URL=https://qa.tapas.io playwright test --project=chromium",
    "test:qa:headed": "TAPAS_BASE_URL=https://qa.tapas.io bddgen && TAPAS_BASE_URL=https://qa.tapas.io playwright test --project=chromium --headed",
    "test:qa:smoke": "TAPAS_BASE_URL=https://qa.tapas.io bddgen && TAPAS_BASE_URL=https://qa.tapas.io playwright test --project=chromium --grep @smoke",
    "dashboard": "node dashboard/server.js",
    "notify:slack": "node scripts/notify-slack.js",
    "test:setup": "playwright test --project=setup --headed",
    "test:setup:unverified": "playwright test tests/auth.unverified.setup.ts --headed",
    "report": "playwright show-report",
    "allure": "allure-commandline generate allure-results --clean -o allure-report && allure-commandline open allure-report",
    "health": "bddgen && playwright test --project=chromium; npm run report",
    "test:mweb": "bddgen && playwright test --project=mobile-safari --project=mobile-safari-common",
    "test:mweb:only": "bddgen && playwright test --project=mobile-safari",
    "test:mweb:common": "bddgen && playwright test --project=mobile-safari-common",
    "test:mweb:headed": "bddgen && playwright test --project=mobile-safari --project=mobile-safari-common --headed",
    "test:mweb:smoke": "bddgen && playwright test --project=mobile-safari --project=mobile-safari-common --grep @smoke"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-playwright": "^3.7.1",
    "dotenv": "^17.4.2",
    "playwright-bdd": "^8.5.0"
  }
}
